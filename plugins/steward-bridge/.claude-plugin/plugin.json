{
  "name": "steward-bridge",
  "description": "Steward Bridge — connect Claude to Steward ACS for tasks, memory, file locks, and error tracking",
  "version": "1.4.0",
  "userConfig": {
    "mcp_api_key": {
      "type": "string",
      "title": "Steward ACS API Key",
      "description": "Your developer API key (starts with acs_dev_)",
      "required": true,
      "sensitive": true
    },
    "acs_url": {
      "type": "string",
      "title": "ACS Server URL",
      "description": "Steward ACS base URL",
      "required": true,
      "sensitive": false,
      "default": "https://prod.stewardacs.xyz"
    }
  },
  "mcpServers": {
    "steward-bridge": {
      "type": "sse",
      "url": "${user_config.acs_url}/mcp/sse?api_key=${user_config.mcp_api_key}",
      "headers": {
        "X-Api-Key": "${user_config.mcp_api_key}"
      }
    }
  }
}
